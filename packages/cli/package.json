{
  "name": "@insoftex/lhremote-cli",
  "version": "0.21.0",
  "description": "CLI for LinkedHelper automation",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "license": "AGPL-3.0-only",
  "author": "Insoftex (https://github.com/insoftex-company)",
  "homepage": "https://github.com/insoftex-company/insoftex-lhremote/tree/main/packages/cli",
  "bugs": "https://github.com/insoftex-company/insoftex-lhremote/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/insoftex-company/insoftex-lhremote.git",
    "directory": "packages/cli"
  },
  "exports": {
    ".": {
      "types": "./dist/program.d.ts",
      "import": "./dist/program.js"
    },
    "./handlers": {
      "types": "./dist/handlers/index.d.ts",
      "import": "./dist/handlers/index.js"
    }
  },
  "bin": {
    "lhremote-cli": "./dist/cli.js"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:e2e": "vitest run --config ../../vitest.e2e.config.ts",
    "lint": "eslint src/",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@insoftex/lhremote-core": "workspace:^",
    "commander": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}

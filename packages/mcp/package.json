{
  "name": "@insoftex/lhremote-mcp",
  "version": "0.22.0",
  "description": "MCP server for LinkedHelper automation",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "license": "AGPL-3.0-only",
  "author": "Insoftex (https://github.com/insoftex-company)",
  "homepage": "https://github.com/insoftex-company/insoftex-lhremote/tree/main/packages/mcp",
  "bugs": "https://github.com/insoftex-company/insoftex-lhremote/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/insoftex-company/insoftex-lhremote.git",
    "directory": "packages/mcp"
  },
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./stdio": {
      "types": "./dist/stdio.d.ts",
      "import": "./dist/stdio.js"
    },
    "./tools": {
      "types": "./dist/tools/index.d.ts",
      "import": "./dist/tools/index.js"
    },
    "./testing": {
      "types": "./dist/tools/testing/mock-server.d.ts",
      "import": "./dist/tools/testing/mock-server.js"
    }
  },
  "bin": {
    "lhremote-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:e2e": "vitest run --config ../../vitest.e2e.config.ts",
    "lint": "eslint src/",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@insoftex/lhremote-core": "workspace:^",
    "@modelcontextprotocol/sdk": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}

{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["build"],
      "cache": false
    },
    "test:e2e": {
      "dependsOn": ["build", "^test:e2e"],
      "passThroughEnv": [
        "LHREMOTE_E2E_PERSON_ID",
        "LHREMOTE_E2E_POST_URL",
        "LHREMOTE_E2E_COMMENT_URN",
        "LHREMOTE_E2E_PROFILE_URL",
        "LHREMOTE_E2E_COMPANY_URL"
      ],
      "cache": false
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}

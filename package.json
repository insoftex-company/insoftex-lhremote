{
  "name": "@insoftex/lhremote-workspace",
  "version": "0.23.5",
  "private": true,
  "license": "AGPL-3.0-only",
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e --concurrency=1",
    "lint": "turbo run lint && pnpm docs:check-command-readmes",
    "license-check": "node scripts/check-licenses.js",
    "docs:sync-command-readmes": "node scripts/update-command-readmes.mjs",
    "docs:check-command-readmes": "node scripts/update-command-readmes.mjs --check",
    "dev": "turbo run dev"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "esbuild": "^0.28.1",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-header": "catalog:",
    "prettier": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  }
}
